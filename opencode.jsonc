{
  "$schema": "https://opencode.ai/config.json",

  // Auto-load Argus identity and review rules
  "instructions": [
    "AGENTS.md",
    "SKILL.md"
  ],

  // Argus is a code review agent - read-only, no modifications
  "agent": {
    "argus": {
      "description": "Frontend design code review agent - specializes in design tokens, a11y, dark mode, hardcoded values",
      "model": "opencode/deepseek-v4-flash-free",
      "mode": "agent",
      "permission": {
        "edit": "deny",
        "write": "deny",
        "bash": "deny"
      }
    }
  },

  // Default to argus agent
  "default_agent": "argus",

  // Read-only mode - argus only reviews, never modifies
  "permission": {
    "edit": "deny",
    "bash": "deny"
  }
}
